# ─────────────────────────── Application ───────────────────────────
APP_NAME="Foundation-Model Auto-Annotation Pipeline"
ENVIRONMENT=local            # local | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true

# ─────────────────────────── Security ──────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_super_secret_key_min_32_chars_long_value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=120

# ─────────────────────────── Database ──────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=annotator
POSTGRES_PASSWORD=annotator
POSTGRES_DB=annotation
# Async + sync DSNs are derived from the above in settings, override if needed:
# DATABASE_URL=postgresql+asyncpg://annotator:annotator@localhost:5432/annotation

# ─────────────────────────── Redis / Broker ────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────── Object storage (S3 / MinIO) ───────────
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=annotations
S3_USE_SSL=false

# ─────────────────────────── ML / Pipeline ─────────────────────────
PIPELINE_MOCK_MODELS=true            # true on CPU-only hosts
DEVICE=cuda                          # cuda | cpu | mps
GDINO_CONFIG_PATH=/weights/groundingdino/config.py
GDINO_WEIGHTS_PATH=/weights/groundingdino/groundingdino_swint_ogc.pth
SAM2_CONFIG=sam2_hiera_l.yaml
SAM2_CHECKPOINT=/weights/sam2/sam2_hiera_large.pt
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k
VLM_PROVIDER=openai                  # openai | azure | mock
OPENAI_API_KEY=
VLM_MODEL=gpt-4o
INFERENCE_BATCH_SIZE=8
MAX_DETECTIONS_PER_IMAGE=100

# ─────────────────────── Confidence thresholds ─────────────────────
CONF_AUTO_APPROVE=0.85
CONF_HUMAN_REVIEW=0.50               # below auto-approve, above reject
CONF_REJECT=0.20                     # below this -> reprocess/reject

# ─────────────────────────── Integrations ──────────────────────────
CVAT_URL=
CVAT_TOKEN=
LABEL_STUDIO_URL=
LABEL_STUDIO_TOKEN=

# ─────────────────────────── MLOps / Observability ─────────────────
MLFLOW_TRACKING_URI=
WANDB_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true

{
  "title": "Auto-Annotation Pipeline",
  "uid": "fm-auto-annotation",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Images processed / sec by routing",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (routing) (rate(pipeline_images_processed_total[5m]))", "legendFormat": "{{routing}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-stage latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(pipeline_stage_seconds_bucket[5m])))", "legendFormat": "{{stage}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Failed images (total)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [ { "expr": "sum(pipeline_images_failed_total)" } ]
    },
    {
      "type": "timeseries",
      "title": "GPU memory per worker (bytes)",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 8 },
      "targets": [ { "expr": "pipeline_gpu_mem_bytes", "legendFormat": "{{instance}}" } ]
    },
    {
      "type": "timeseries",
      "title": "API request latency p95 (s)",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, path) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{path}}" }
      ]
    }
  ]
}
